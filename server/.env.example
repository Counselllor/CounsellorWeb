# ===========================================
# Environment Variables for Counsellor Web App
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit the .env file to version control!

# ===========================================
# DATABASE
# ===========================================
# MongoDB connection string
# For local development: mongodb://localhost:27017/counsellor_db
# For MongoDB Atlas: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/counsellor_db

# ===========================================
# AUTHENTICATION
# ===========================================
# JWT secret key for signing tokens (use a long random string in production)
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_key_here

# ===========================================
# SERVER
# ===========================================
# Port for the server to listen on
PORT=5000

# Node environment (development, production, test)
NODE_ENV=development

# ===========================================
# CORS
# ===========================================
# Client origin URL for CORS
# Comma-separated for multiple origins (e.g., http://localhost:3000,https://yourdomain.com)
# Use "*" to allow all origins (NOT recommended for production)
CLIENT_ORIGIN=http://localhost:3000

# ===========================================
# CLOUDINARY (Image Upload)
# ===========================================
# Get these from your Cloudinary dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ===========================================
# EMAIL (For Forgot Password)
# ===========================================
# Gmail: enable "App Passwords" at https://myaccount.google.com/apppasswords
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=your_email@gmail.com
